# Host identity
HOSTNAME=homelab
TIMEZONE=UTC
LOCALE=en_US.UTF-8

# Admin user
USERNAME=admin
USER_DESCRIPTION=Homelab admin
SUDO_NEEDS_PASSWORD=true

# Networking
INTERFACE=eth0
USE_DHCP=true
STATIC_IP=192.168.1.50
PREFIX_LENGTH=24
GATEWAY=192.168.1.1
NAMESERVERS=1.1.1.1,9.9.9.9
ENABLE_IPV6=false

# SSH
SSH_PORT=22
SSH_OPEN_FIREWALL=false
SSH_PASSWORD_AUTH=false
SSH_AUTHORIZED_KEYS_FILE=
SSH_AUTHORIZED_KEYS=ssh-ed25519 AAAA... you@host

# Tailscale
TAILSCALE_AUTHKEY_FILE=/etc/tailscale/authkey

# Control API and deployment
CONTROL_API_PORT=9092
REPO_URL=https://github.com/Val-k7/HomeLab

# Standalone UI access control (oauth2-proxy). Set at least one — the build
# refuses an open auth front. Restrict to a GitHub org and/or explicit logins.
OAUTH2_GITHUB_ORG=
OAUTH2_GITHUB_USERS=changeme
